{
  "name": "otd",
  "version": "2.0.0",
  "private": true,
  "description": "On This Day...",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "start": "nuxt dev",
    "dev:e2e": "nuxt dev --hostname 0.0.0.0 --port 4173",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "vitest --run",
    "typecheck": "nuxi typecheck",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm test && npm run e2e && npm run build",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:vrt": "VRT=1 playwright test",
    "e2e:vrt:baseline": "VRT=1 playwright test --update-snapshots",
    "e2e:vrt:report": "playwright show-report",
    "e2e:vrt:docker": "./scripts/vrt-docker.sh",
    "e2e:vrt:baseline:docker": "./scripts/vrt-docker.sh baseline"
  },
  "dependencies": {
    "@vite-pwa/nuxt": "^1.1.1",
    "cheerio": "^1.2.0",
    "ical-generator": "^10.1.0",
    "luxon": "^3.7.2",
    "node-cache": "^5.1.2",
    "nuxt": "^4.4.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.4",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@playwright/test": "^1.58.2",
    "@types/luxon": "^3.7.1",
    "@vue/test-utils": "^2.4.6",
    "commander": "^14.0.3",
    "happy-dom": "^20.8.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.6"
  }
}
